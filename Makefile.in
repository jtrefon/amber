CXX       = @CXX@
CXXFLAGS  = @CXXFLAGS@
CPPFLAGS  = @CPPFLAGS@
# Auto-generate header dependency files (.d) so editing a header rebuilds every
# translation unit that includes it. Without this, struct-layout changes in
# headers leave stale .o files -> ABI mismatch -> heap corruption at runtime.
DEPFLAGS  = -MMD -MP
CURL_CFLAGS = @CURL_CFLAGS@
CURL_LIBS   = @CURL_LIBS@

prefix    = @prefix@
bindir    = @bindir@
libdir    = @libdir@
includedir = @includedir@
datarootdir = @datarootdir@
docdir    = $(datarootdir)/doc/amber

SRC_DIR   = @srcdir@
BUILD_DIR = @builddir@

LIB_OBJS  = $(BUILD_DIR)/lib/config.o \
            $(BUILD_DIR)/lib/llm.o \
            $(BUILD_DIR)/lib/registry.o \
            $(BUILD_DIR)/lib/prompt.o \
            $(BUILD_DIR)/lib/agent.o \
            $(BUILD_DIR)/lib/statusbar.o \
            $(BUILD_DIR)/lib/session.o \
            $(BUILD_DIR)/lib/workspace.o \
            $(BUILD_DIR)/lib/tools_default.o \
            $(BUILD_DIR)/tools/read_tool.o \
            $(BUILD_DIR)/tools/write_tool.o \
            $(BUILD_DIR)/tools/search_tool.o \
            $(BUILD_DIR)/tools/search/grep_backend.o \
            $(BUILD_DIR)/tools/search/semantic_backend.o

CLI_OBJ   = $(BUILD_DIR)/src/main.o
TUI_OBJS  = $(BUILD_DIR)/tui/tui.o \
            $(BUILD_DIR)/tui/widgets.o \
            $(BUILD_DIR)/tui/textutil.o \
            $(BUILD_DIR)/tui/palette.o
TEST_OBJ  = $(BUILD_DIR)/src/smoketest.o
UNITTEST_OBJ = $(BUILD_DIR)/tests/run_tests.o

LIBNAME   = libagent.a
CLI_BIN   = amber
TUI_BIN   = amber-tui

# ncurses (+ form/menu/panel) for the TUI client (detected at configure time).
NCURSES_LIBS = @NCURSES_LIBS@
NCURSES_CFLAGS = @NCURSES_CFLAGS@

.PHONY: all lib cli tui check test clean install uninstall

all: lib cli tui

check: $(BUILD_DIR)/smoketest
	$(BUILD_DIR)/smoketest

test: $(BUILD_DIR)/run_tests
	$(BUILD_DIR)/run_tests

$(BUILD_DIR)/run_tests: $(UNITTEST_OBJ) $(BUILD_DIR)/tui/textutil.o $(BUILD_DIR)/tui/palette.o $(BUILD_DIR)/$(LIBNAME)
	$(CXX) $(CXXFLAGS) -o $@ $(UNITTEST_OBJ) $(BUILD_DIR)/tui/textutil.o $(BUILD_DIR)/tui/palette.o $(BUILD_DIR)/$(LIBNAME) $(CURL_LIBS)

$(BUILD_DIR)/smoketest: $(TEST_OBJ) $(BUILD_DIR)/$(LIBNAME)
	$(CXX) $(CXXFLAGS) -o $@ $(TEST_OBJ) $(BUILD_DIR)/$(LIBNAME) $(CURL_LIBS)

lib: $(BUILD_DIR)/$(LIBNAME)

$(BUILD_DIR)/$(LIBNAME): $(LIB_OBJS)
	$(AR) rcs $@ $(LIB_OBJS)

cli: $(BUILD_DIR)/$(CLI_BIN)

$(BUILD_DIR)/$(CLI_BIN): $(CLI_OBJ) $(BUILD_DIR)/$(LIBNAME)
	$(CXX) $(CXXFLAGS) -o $@ $(CLI_OBJ) $(BUILD_DIR)/$(LIBNAME) \
	    $(CURL_LIBS)

tui: $(BUILD_DIR)/$(TUI_BIN)

$(BUILD_DIR)/$(TUI_BIN): $(TUI_OBJS) $(BUILD_DIR)/$(LIBNAME)
	$(CXX) $(CXXFLAGS) -o $@ $(TUI_OBJS) $(BUILD_DIR)/$(LIBNAME) \
	    $(CURL_LIBS) $(NCURSES_LIBS)

# Object compilation rules. The library and tools are compiled once into the
# archive; the CLI/TUI only link against it.
$(BUILD_DIR)/lib/%.o: $(SRC_DIR)/lib/%.cpp
	@mkdir -p $(BUILD_DIR)/lib
	$(CXX) $(CXXFLAGS) $(CPPFLAGS) $(DEPFLAGS) $(CURL_CFLAGS) -c $< -o $@

$(BUILD_DIR)/src/%.o: $(SRC_DIR)/src/%.cpp
	@mkdir -p $(BUILD_DIR)/src
	$(CXX) $(CXXFLAGS) $(CPPFLAGS) $(DEPFLAGS) $(CURL_CFLAGS) -c $< -o $@

$(BUILD_DIR)/tui/%.o: $(SRC_DIR)/tui/%.cpp
	@mkdir -p $(BUILD_DIR)/tui
	$(CXX) $(CXXFLAGS) $(CPPFLAGS) $(DEPFLAGS) $(CURL_CFLAGS) $(NCURSES_CFLAGS) -c $< -o $@

$(BUILD_DIR)/tools/%.o: $(SRC_DIR)/tools/%.cpp
	@mkdir -p $(BUILD_DIR)/tools/search
	$(CXX) $(CXXFLAGS) $(CPPFLAGS) $(DEPFLAGS) $(CURL_CFLAGS) -c $< -o $@

$(BUILD_DIR)/tests/%.o: $(SRC_DIR)/tests/%.cpp
	@mkdir -p $(BUILD_DIR)/tests
	$(CXX) $(CXXFLAGS) $(CPPFLAGS) $(DEPFLAGS) $(CURL_CFLAGS) -c $< -o $@

# Pull in auto-generated header dependencies (ignored if absent, e.g. first run).
-include $(LIB_OBJS:.o=.d)
-include $(CLI_OBJ:.o=.d)
-include $(TUI_OBJS:.o=.d)
-include $(UNITTEST_OBJ:.o=.d)
-include $(TEST_OBJ:.o=.d)

install: all
	install -d $(DESTDIR)$(bindir)
	install -m 755 $(BUILD_DIR)/$(CLI_BIN) $(DESTDIR)$(bindir)/
	install -m 755 $(BUILD_DIR)/$(TUI_BIN) $(DESTDIR)$(bindir)/
	install -d $(DESTDIR)$(libdir)
	install -m 644 $(BUILD_DIR)/$(LIBNAME) $(DESTDIR)$(libdir)/
	install -d $(DESTDIR)$(includedir)/agent
	install -d $(DESTDIR)$(includedir)/nlohmann
	install -m 644 $(SRC_DIR)/include/agent/*.h $(DESTDIR)$(includedir)/agent/
	install -m 644 $(SRC_DIR)/include/nlohmann/json.hpp $(DESTDIR)$(includedir)/nlohmann/
	install -d $(DESTDIR)$(docdir)
	install -m 644 $(SRC_DIR)/LICENSE $(DESTDIR)$(docdir)/
	install -m 644 $(SRC_DIR)/NOTICE $(DESTDIR)$(docdir)/
	install -m 644 $(SRC_DIR)/THIRD_PARTY_LICENSES $(DESTDIR)$(docdir)/
	install -m 644 $(SRC_DIR)/README.md $(DESTDIR)$(docdir)/

uninstall:
	rm -f $(DESTDIR)$(bindir)/$(CLI_BIN)
	rm -f $(DESTDIR)$(bindir)/$(TUI_BIN)
	rm -f $(DESTDIR)$(libdir)/$(LIBNAME)
	rm -rf $(DESTDIR)$(includedir)/agent
	rm -rf $(DESTDIR)$(docdir)

clean:
	rm -f $(BUILD_DIR)/lib/*.o $(BUILD_DIR)/src/*.o $(BUILD_DIR)/tui/*.o $(BUILD_DIR)/tests/*.o
	rm -f $(BUILD_DIR)/tools/*.o $(BUILD_DIR)/tools/search/*.o
	rm -f $(BUILD_DIR)/lib/*.d $(BUILD_DIR)/src/*.d $(BUILD_DIR)/tui/*.d \
	      $(BUILD_DIR)/tests/*.d $(BUILD_DIR)/tools/*.d $(BUILD_DIR)/tools/search/*.d
	rm -f $(BUILD_DIR)/$(LIBNAME) $(BUILD_DIR)/$(CLI_BIN) $(BUILD_DIR)/$(TUI_BIN)
	rm -f $(BUILD_DIR)/smoketest $(BUILD_DIR)/run_tests
