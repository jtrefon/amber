---
# clang-tidy configuration for amber (cpp-agent).
# Keep the checks conservative: surface real bugs (null derefs, leaks,
# use-after-move, uninitialized reads) and modernization nits worth taking,
# without noisy style opinions (clang-format owns style) or pedantic
# identifier checks that clash with this codebase's conventions.
Checks: >
  -*,
  bugprone-*,
  performance-*,
  modernize-*,
  readability-*,
  clang-analyzer-*,
  -modernize-use-trailing-return-type,
  -readability-identifier-length,
  -readability-magic-numbers,
  -readability-convert-member-functions-to-static,
  -readability-avoid-const-params-in-decls,
  -bugprone-easily-swappable-parameters,
  -performance-no-int-to-ptr,
  -modernize-use-nodiscard,
  -readability-function-cognitive-complexity,
  -readability-braces-around-statements,
  -readability-implicit-bool-conversion,
  -readability-named-parameter,
  -readability-qualified-auto,
  -readability-suspicious-call-argument,
  -readability-isolate-declaration,
  -readability-use-std-min-max,
  -modernize-avoid-c-arrays,
  -readability-uppercase-literal-suffix,
  -performance-unnecessary-copy-initialization,
  -bugprone-narrowing-conversions,
  -cppcoreguidelines-*,
  -google-*,
  -abseil-*

WarningsAsErrors: ''
HeaderFilterRegex: 'include/agent/.*\.h'
FormatStyle: file
